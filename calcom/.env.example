# Copy to calcom/.env before starting the Cal.com stack:
# cp calcom/.env.example calcom/.env

CALCOM_POSTGRES_USER=calcom
CALCOM_POSTGRES_PASSWORD=CHANGE_ME_CALCOM_DB_PASSWORD
CALCOM_POSTGRES_DB=calcom
CALCOM_DATABASE_URL=postgresql://calcom:CHANGE_ME_CALCOM_DB_PASSWORD@calcom-postgres:5432/calcom

CALCOM_NEXTAUTH_SECRET=CHANGE_ME_GENERATE_32_BYTE_HEX
CALCOM_ENCRYPTION_KEY=CHANGE_ME_GENERATE_32_BYTE_HEX

CALCOM_NEXT_PUBLIC_WEBAPP_URL=http://localhost:3001
CALCOM_NEXT_PUBLIC_WEBSITE_URL=http://localhost:3001
CALCOM_NEXTAUTH_URL=http://localhost:3001/api/auth

# Optional future public alternatives:
# CALCOM_NEXT_PUBLIC_WEBAPP_URL=https://calendar.valueflow.eco
# CALCOM_NEXT_PUBLIC_WEBSITE_URL=https://calendar.valueflow.eco
# CALCOM_NEXTAUTH_URL=https://calendar.valueflow.eco/api/auth

# Enable organizations/teams for routing workflows.
CALCOM_ORGANIZATIONS_ENABLED=1

# Optional future values:
# CALCOM_LICENSE_KEY=
# CALCOM_EMAIL_FROM=
# CALCOM_EMAIL_SERVER_HOST=
# CALCOM_EMAIL_SERVER_PORT=
# CALCOM_EMAIL_SERVER_USER=
# CALCOM_EMAIL_SERVER_PASSWORD=
