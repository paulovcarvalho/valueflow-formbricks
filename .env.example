WEBAPP_URL=http://localhost:3000
# Optional future public alternative:
# WEBAPP_URL=https://forms.valueflow.eco
NEXTAUTH_URL=http://localhost:3000
# Optional future public alternative:
# NEXTAUTH_URL=https://forms.valueflow.eco
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/formbricks?schema=public
NEXTAUTH_SECRET=CHANGE_ME_GENERATE_32_BYTE_HEX
ENCRYPTION_KEY=CHANGE_ME_GENERATE_32_BYTE_HEX
CRON_SECRET=CHANGE_ME_GENERATE_32_BYTE_HEX
S3_ACCESS_KEY=CHANGE_ME_RUSTFS_ACCESS_KEY
S3_SECRET_KEY=CHANGE_ME_RUSTFS_SECRET_KEY
S3_REGION=us-east-1
S3_BUCKET_NAME=formbricks-storage
S3_ENDPOINT_URL=http://localhost:9000
# Formbricks shares RustFS network namespace so localhost:9000 works in both browser and container.
# Optional future public alternative:
# S3_ENDPOINT_URL=https://forms.valueflow.eco
S3_FORCE_PATH_STYLE=1
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
